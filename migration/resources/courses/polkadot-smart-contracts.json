          "quizData": [
            {
              "id": "q-ink-2-1",
              "question": {
                "EN": "Why use `ink::storage::Mapping` instead of `HashMap`?",
                "ES": "¿Por qué usar `ink::storage::Mapping` en lugar de `HashMap`?"
              },
              "options": {
                "EN": [
                  "It is faster in RAM",
                  "It loads values lazily from storage",
                  "It supports more types"
                ],
                "ES": [
                  "Es más rápido en RAM",
                  "Carga valores perezosamente del almacenamiento",
                  "Soporta más tipos"
                ]
              },
              "correctIndex": 1,
              "explanation": {
                "EN": "`HashMap` loads all data into memory (gas expensive). `Mapping` only loads the requested key.",
                "ES": "`HashMap` carga todo en memoria (caro en gas). `Mapping` solo carga la clave pedida."
              }
            },
            {
              "id": "q-ink-2-2",
              "question": {
                "EN": "What encoding does Substrate/ink! use?",
                "ES": "¿Qué codificación usa Substrate/ink!?"
              },
              "options": {
                "EN": [
                  "JSON",
                  "Protobuf",
                  "SCALE"
                ],
                "ES": [
                  "JSON",
                  "Protobuf",
                  "SCALE"
                ]
              },
              "correctIndex": 2,
              "explanation": {
                "EN": "Simple Concatenated Aggregate Little-Endian (SCALE) is the standard lightweight codec.",
                "ES": "Simple Concatenated Aggregate Little-Endian (SCALE) es el codec ligero estándar."
              }
            }
          ]
        }
      ]
