                  "#[ink(state)]"
                ],
                "ES": [
                  "#[ink(storage)]",
                  "#[ink(data)]",
                  "#[ink(state)]"
                ]
              },
              "correctIndex": 0,
              "explanation": {
                "EN": "`#[ink(storage)]` marks the struct that represents persistent state.",
