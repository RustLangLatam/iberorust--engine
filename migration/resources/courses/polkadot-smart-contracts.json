      "chapters": [
        {
          "id": "chap-ink-1-1",
          "courseId": "polkadot-smart-contracts",
          "order": 1,
          "type": "concept",
          "title": {
            "EN": "Substrate & Contracts Pallet",
            "ES": "Substrate y Contracts Pallet"
          },
          "content": {
            "EN": "ink! targets the contracts pallet.",
            "ES": "ink! apunta al pallet de contratos."
          },
          "codeSnippet": "// ink! smart contract structure\n#![cfg_attr(not(feature = \"std\"), no_std)]\n\n#[ink::contract]\nmod flipper {\n    /// Defines the storage of your contract.\n    #[ink(storage)]\n    pub struct Flipper {\n        value: bool,\n    }\n\n    impl Flipper {\n        /// Constructor: Initializes the contract\n        #[ink(constructor)]\n        pub fn new(init_value: bool) -> Self {\n            Self { value: init_value }\n        }\n\n        /// Message: A public function that can be called by users\n        /// Flips the current value of the boolean.\n        #[ink(message)]\n        pub fn flip(&mut self) {\n            self.value = !self.value;\n        }\n\n        /// Message: Simply returns the current value.\n        #[ink(message)]\n        pub fn get(&self) -> bool {\n            self.value\n        }\n    }\n}\n\nfn main() {\n    println!(\"ink! contracts compile to WASM for the Polkadot ecosystem.\");\n}",
          "hasVideo": true
        },
