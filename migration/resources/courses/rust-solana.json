          "quizData": [
            {
              "id": "q-sol-1-1",
              "question": {
                "EN": "Where is state stored in Solana?",
                "ES": "¿Dónde se guarda el estado en Solana?"
              },
              "options": {
                "EN": [
                  "Inside the Program",
                  "In Data Accounts",
                  "In the Block Header"
                ],
                "ES": [
                  "Dentro del Programa",
                  "En Cuentas de Datos",
                  "En el Block Header"
                ]
              },
              "correctIndex": 1,
              "explanation": {
                "EN": "Programs are stateless. Data lives in separate accounts owned by the program.",
                "ES": "Los programas son sin estado. Los datos viven en cuentas separadas propiedad del programa."
              }
            },
            {
              "id": "q-sol-1-2",
              "question": {
                "EN": "What allows Solana to execute transactions in parallel?",
                "ES": "¿Qué permite a Solana ejecutar transacciones en paralelo?"
              },
              "options": {
                "EN": [
                  "Sharding",
                  "Specifying all accessed accounts upfront",
                  "Proof of History"
                ],
                "ES": [
                  "Sharding",
                  "Especificar todas las cuentas accedidas por adelantado",
                  "Proof of History"
                ]
              },
              "correctIndex": 1,
              "explanation": {
                "EN": "By knowing which accounts are touched, the runtime can schedule non-overlapping transactions on different cores.",
                "ES": "Al saber qué cuentas se tocan, el runtime puede agendar transacciones no solapadas en núcleos diferentes."
              }
            }
          ]
        }
      ]
